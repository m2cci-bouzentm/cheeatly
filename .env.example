# ─────────────────────────────────────────────────────────────────────────────
# Cheatly — environment variables read by the app and build scripts.
#
# LLM API keys (Gemini, OpenAI, Claude, Groq, Deepseek) are NOT configured
# here. Enter them in Settings → AI Providers; stored in the OS keychain.
# ─────────────────────────────────────────────────────────────────────────────

# ── macOS code signing (stable TCC grants across rebuilds) ──────────────────
CHEATLY_LOCAL_SIGN_IDENTITY="Apple Development: you@example.com (TEAMID)"

# ── Local Parakeet STT engine (optional overrides) ──────────────────────────
# SPEECH_TO_TEXT_BINARY=/path/to/speech-to-text
# SPEECH_TO_TEXT_MODEL=/path/to/models/parakeet
# SPEECH_TO_TEXT_TIMEOUT_MS=30000

# ── Dev / debug flags ──────────────────────────────────────────────────────
# CHEATLY_DEV_BYPASS_SCREEN_TCC=1     # skip macOS screen-capture permission gate in dev
# CHEATLY_ADHOC_HARDENED=1            # ad-hoc sign with hardened runtime

# ── Build / signing (CI or production) ──────────────────────────────────────
# CHEATLY_BUILD_ALL_MAC_ARCHES=1      # native modules for x64 + arm64
# CHEATLY_PRODUCTION_SIGN=1           # require Developer ID signing
# CHEATLY_SIGN_IDENTITY="Developer ID Application: …"
# CSC_NAME= / CSC_LINK=               # electron-builder signing identity
