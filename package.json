{
  "name": "cheatly",
  "version": "0.0.1",
  "main": "dist-main/main/main.js",
  "description": "Cheatly is a meeting notes app that uses AI to generate notes from your meetings.",
  "scripts": {
    "clean": "rimraf dist dist-main",
    "dev": "vite",
    "format": "prettier --write \"{core,main,renderer,scripts,tests}/**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\" \"*.{json,js,cjs,mjs,ts,md}\"",
    "format:check": "prettier --check \"{core,main,renderer,scripts,tests}/**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\" \"*.{json,js,cjs,mjs,ts,md}\"",
    "build": "npm run clean && tsc && vite build",
    "build:electron": "node scripts/build-electron.js",
    "build:main:tsc": "tsc -p main/tsconfig.json",
    "typecheck:main": "tsc -p main/tsconfig.json --noEmit",
    "preview": "vite preview",
    "postinstall": "node scripts/rebuild-native-electron.js && node scripts/patch-electron-plist.js && node scripts/verify-native-arch.js && npx prisma generate",
    "db:generate": "prisma generate",
    "rebuild:native": "node scripts/rebuild-native-electron.js && node scripts/verify-native-arch.js",
    "electron:dev": "npm run build:electron && cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build:electron && cross-env NODE_ENV=production electron .",
    "app:dev": "concurrently \"npm run dev -- --port 5180 --strictPort\" \"wait-on http://localhost:5180 && npm run electron:dev\"",
    "app:build": "rimraf release && npm run build && npm run build:electron && cross-env CHEATLY_BUILD_ALL_MAC_ARCHES=1 npm run build:native && electron-builder && npm run rebuild:native",
    "app:build:signed": "rimraf release && npm run build && npm run build:electron && cross-env CHEATLY_BUILD_ALL_MAC_ARCHES=1 npm run build:native && electron-builder --config electron-builder.signed.cjs",
    "watch": "tsc -p main/tsconfig.json --watch",
    "start": "npm run app:dev",
    "dist": "npm run app:build",
    "dist:fast": "rimraf release && npm run build && npm run build:electron && npx electron-builder && npm run rebuild:native",
    "dist:signed": "npm run app:build:signed",
    "build:native": "node scripts/build-native.js",
    "test": "npm run build:electron && npm run test:unit && npm run test:unit:stt",
    "test:unit": "node --test $(find main/test renderer/test -name '*.test.mjs' ! -name '*Parakeet*')",
    "test:unit:stt": "node --test --test-concurrency=1 main/test/audio/*Parakeet*.test.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:parity": "ELECTRON_E2E=1 ELECTRON_APP_PORT=${ELECTRON_APP_PORT:-5173} npx playwright test tests/e2e/parity-gaps-evidence.spec.ts",
    "doctor": "npx react-doctor@latest"
  },
  "build": {
    "generateUpdatesFilesForAllChannels": true,
    "appId": "com.cheatly.assistant",
    "afterPack": "./scripts/ad-hoc-sign.js",
    "productName": "Cheatly",
    "files": [
      "dist",
      "dist-main",
      "platform-bridge",
      "package.json",
      "node_modules",
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma"
      },
      "!**/platform-bridge/target",
      "!**/platform-bridge/src",
      "!**/platform-bridge/.cargo"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dylib",
      "**/.prisma/**"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "assets/cheatly.icns",
        "to": "cheatly.icns"
      },
      {
        "from": "local-stt-engine/.build/release/speech-to-text",
        "to": "local-stt-engine/speech-to-text"
      },
      {
        "from": "core/resources/prompts/",
        "to": "prompts/"
      },
      {
        "from": "core/resources/skills/",
        "to": "skills/"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/cheatly.icns",
      "identity": null,
      "hardenedRuntime": false,
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Cheatly needs Screen Recording permission to capture system audio for meeting transcription.",
        "NSMicrophoneUsageDescription": "Cheatly needs microphone access to transcribe your voice during meetings.",
        "NSAudioCaptureUsageDescription": "Cheatly needs system audio access to transcribe meeting audio."
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/win/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/png/",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Cheatly-AI-assistant",
        "repo": "cheatly",
        "releaseType": "release"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.21.5",
    "fallow": "^2.93.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "prisma": "^6.9.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.1"
  },
  "prisma": {
    "schema": "core/prisma/schema.prisma"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@ai-sdk/react": "^3.0.200",
    "@opendocsg/pdf2md": "^0.2.7",
    "@prisma/client": "^6.9.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-query": "^5.100.10",
    "ai": "^6.0.198",
    "better-sqlite3": "12.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.29.2",
    "jspdf": "^4.0.0",
    "katex": "^0.16.27",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "overrides": {}
}
