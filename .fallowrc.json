{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "main/main.ts",
    "main/preload/index.ts",
    "core/src/index.ts",
    "main/test/**/*.{mjs,ts}",
    "core/src/test/**/*.ts",
    "renderer/test/**/*.mjs",
    "tests/**/*.{ts,mjs}",
    "scripts/*.{js,cjs,mjs}"
  ],
  "ignorePatterns": ["platform-bridge/index.js"],
  "ignoreExports": [
    {
      "file": "core/src/index.ts",
      "exports": ["*"]
    },
    {
      "file": "main/ipc/meetingHandlers.ts",
      "exports": ["mapMeeting"]
    },
    {
      "file": "main/test/services/ipcTestUtils.mjs",
      "exports": ["*"]
    },
    {
      "file": "playwright.config.ts",
      "exports": ["*"]
    },
    {
      "file": "postcss.config.js",
      "exports": ["*"]
    },
    {
      "file": "renderer/lib/*.d.mts",
      "exports": ["*"]
    },
    {
      "file": "renderer/lib/overlayAppearance.ts",
      "exports": ["*"]
    },
    {
      "file": "renderer/pages/AssistantOverlay/types.ts",
      "exports": ["*"]
    },
    {
      "file": "scripts/ad-hoc-sign.js",
      "exports": ["*"]
    },
    {
      "file": "tailwind.config.js",
      "exports": ["*"]
    },
    {
      "file": "tests/intelligence-fixtures/fixture-set.mjs",
      "exports": ["*"]
    }
  ],
